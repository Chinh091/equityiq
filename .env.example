# LLM serving
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=llama3.3:70b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen2.5:32b-instruct
OLLAMA_JUDGE_MODEL=qwen2.5:32b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5
OLLAMA_KEEP_ALIVE=30m
OLLAMA_REQUEST_TIMEOUT_S=300

# Reranker (TEI)
RERANKER_BASE_URL=http://localhost:8081
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Postgres (pgvector)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=equityiq
POSTGRES_USER=equityiq
POSTGRES_PASSWORD=equityiq_dev

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=equityiq_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Langfuse (self-hosted)
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# External data APIs
SEC_EDGAR_USER_AGENT=EquityIQ research-portfolio your-email@example.com
FINNHUB_API_KEY=
NEWSAPI_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
